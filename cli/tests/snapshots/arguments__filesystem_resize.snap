    global: GlobalOptions {
        verbose: 0,
        quiet: false,
        dry_run: false,
        log: None,
        format: None,
    },
    command: Filesystem(
        FilesystemCommand {
            subcommand: Resize(
                FilesystemResizeCommand {
                    enqueue: false,
                    offline: false,
                    size: "+1G",
                    path: "/mnt",
                },
            ),
        },
    ),
}
