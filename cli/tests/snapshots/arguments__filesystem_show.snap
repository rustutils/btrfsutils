---
source: cli/tests/arguments.rs
expression: "parse(&[\"btrfs\", \"filesystem\", \"show\", \"/mnt\"])"
---
Arguments {
    global: GlobalOptions {
        verbose: false,
        quiet: false,
        dry_run: false,
        log: None,
        format: None,
    },
    command: Filesystem(
        FilesystemCommand {
            subcommand: Show(
                FilesystemShowCommand {
                    all_devices: false,
                    mounted: false,
                    filter: Some(
                        "/mnt",
                    ),
                },
            ),
        },
    ),
}
