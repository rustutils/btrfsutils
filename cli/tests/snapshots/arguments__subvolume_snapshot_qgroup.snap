Arguments {
    global: GlobalOptions {
        verbose: false,
        quiet: false,
        dry_run: false,
        log: None,
        format: None,
    },
    command: Subvolume(
        SubvolumeCommand {
            subcommand: Snapshot(
                SubvolumeSnapshotCommand {
                    readonly: false,
                    qgroups: [
                        "0/100",
                    ],
                    source: "/mnt/src",
                    dest: "/mnt/dst",
                },
            ),
        },
    ),
}
