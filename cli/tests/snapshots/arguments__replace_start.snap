---
Arguments {
    global: GlobalOptions {
        verbose: 0,
        quiet: false,
        dry_run: false,
        log: None,
        format: None,
    },
    command: Replace(
        ReplaceCommand {
            subcommand: Start(
                ReplaceStartCommand {
                    source: "/dev/sda",
                    target: "/dev/sdb",
                    mount_point: "/mnt",
                    redundancy_only: false,
                    force: false,
                    no_background: false,
                    enqueue: false,
                    nodiscard: false,
                },
            ),
        },
    ),
}
