    global: GlobalOptions {
        verbose: 0,
        quiet: false,
        dry_run: false,
        log: None,
        format: None,
    },
    command: Reflink(
        ReflinkCommand {
            subcommand: Clone(
                ReflinkCloneCommand {
                    ranges: [
                        "0:4096:8192",
